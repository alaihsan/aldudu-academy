DATABASE_URL=mysql+pymysql://root:password@localhost:3306/aldudu_academy

# SECURITY: SECRET_KEY must be at least 32 characters for production
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here-minimum-32-characters-long-for-security

# Email (Mailtrap for development — get credentials from mailtrap.io)
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_SENDER_NAME=Aldudu Academy
MAIL_SENDER_EMAIL=noreply@aldudu.academy
APP_URL=http://localhost:5000

# Sentry Error Tracking (Get DSN from https://sentry.io)
# Create a new Flask project in Sentry and copy the DSN
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=aldudu-academy@1.0.0

# Celery/Redis (Required for background tasks like Rasch analysis)
# Install Redis: https://redis.io/download
# Start Redis: redis-server
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Prometheus Metrics
PROMETHEUS_ENABLED=true
