__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/

# Instance folder contains local config and the sqlite database
/instance/config.py


# Env files (credentials — never commit)
.env
.env.local
.env.production

# Deploy artifacts and logs
/deploy/*.env
/deploy/*.log
/backups/
gunicorn.log
flask.log

# Editor backups
*.swp
.DS_Store

# Claude Code worktrees (workspace-specific, not project code)
.claude/worktrees/
